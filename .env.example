# WeChat Official Account Configuration
WECHAT_APP_ID=your_app_id_here
WECHAT_APP_SECRET=your_app_secret_here
WECHAT_TEMPLATE_ID=your_template_id_here
WECHAT_TOKEN=your_token_for_server_validation
WECHAT_ENCODING_AES_KEY=your_encoding_aes_key_for_message_encryption

# Person 1 (Lain - at home in Wuxi, China)
PERSON1_OPENID=openid_for_lain
PERSON1_NAME=Lain
PERSON1_LOCATION=Wuxi, China
PERSON1_LATITUDE=31.5754
PERSON1_LONGITUDE=120.3155

# Person 2 (Brother - in Chicago, USA)
PERSON2_OPENID=openid_for_brother
PERSON2_NAME=Brother
PERSON2_LOCATION=Chicago, USA
PERSON2_LATITUDE=41.8781
PERSON2_LONGITUDE=-87.6298

# Wind Weather API Configuration
WIND_WEATHER_API_KEY=your_wind_weather_api_key
WIND_WEATHER_BASE_URL=https://api.weatherapi.com/v1

# Server Configuration
PORT=3000
NODE_ENV=production

# Schedule Configuration
SCHEDULE_TIME=10:00
TIMEZONE=Asia/Shanghai

# Logging
LOG_LEVEL=info
